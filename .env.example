# ============================================================
# NEXO ONE ERP — Variáveis de Ambiente
# ============================================================
# COPIE ESTE ARQUIVO PARA .env E CONFIGURE OS VALORES
# NUNCA COMMIT O ARQUIVO .env — ele está no .gitignore
# ============================================================

# ═══════════════════════════════════════════════════════════
# AMBIENTE
# ═══════════════════════════════════════════════════════════
APP_ENV=development
# APP_ENV=production
LOG_LEVEL=debug
PORT=8080

# ═══════════════════════════════════════════════════════════
# BANCO DE DADOS (PostgreSQL 16)
# ═══════════════════════════════════════════════════════════
# Formato: postgres://usuario:senha@host:porta/banco?sslmode=disable
DATABASE_URL=postgres://nexo_api:SENHA_FORTE_AQUI@localhost:5432/nexo_one?sslmode=disable

# Senha separada (para docker-compose)
DB_PASSWORD=SENHA_FORTE_AQUI

# ═══════════════════════════════════════════════════════════
# REDIS (Cache e Sessões)
# ═══════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════
# NATS (Event Bus / Mensageria)
# ═══════════════════════════════════════════════════════════
NATS_URL=nats://localhost:4222

# ═══════════════════════════════════════════════════════════
# SEGURANÇA (JWT)
# ═══════════════════════════════════════════════════════════
# OBRIGATÓRIO: Gere um segredo forte (mínimo 32 caracteres)
# Exemplo: openssl rand -base64 32
JWT_SECRET=TROQUE_ESTE_SEGREDO_EM_PRODUCAO_32_CHARS_MINIMO

# ═══════════════════════════════════════════════════════════
# URLs
# ═══════════════════════════════════════════════════════════
BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════
# INTEGRAÇÕES OPCIONAIS
# ═══════════════════════════════════════════════════════════

# WhatsApp Business API (para aprovação de OS)
# WHATSAPP_TOKEN=seu_token_aqui

# BaaS - Banking as a Service (PIX/Boleto)
# BAAS_PROVIDER=celcoin
# BAAS_API_KEY=sua_chave_aqui
# BAAS_SECRET_KEY=sua_chave_secreta

# SEFAZ - Certificado Digital A1 (para NF-e/CT-e)
# SEFAZ_CERT_PATH=/etc/nexo/cert.pfx
# SEFAZ_CERT_PASSWORD=senha_do_certificado
# SEFAZ_AMBIENTE=homologacao
# SEFAZ_AMBIENTE=producao

# ═══════════════════════════════════════════════════════════
# LIMITES E PERFORMANCE
# ═══════════════════════════════════════════════════════════
# Conexões do pool PostgreSQL
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# Cache de alíquotas NCM (segundos)
NCM_CACHE_TTL=86400

# ============================================================
# NOTAS DE SEGURANÇA:
# 
# 1. Em PRODUÇÃO, use senhas fortes geradas aleatoriamente
# 2. NUNCA exponha este arquivo publicamente
# 3. Use variáveis de ambiente do sistema ou secrets manager
# 4. O JWT_SECRET deve ser único por ambiente
# ============================================================
